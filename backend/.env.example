# FashionFusion Environment Configuration - PostgreSQL + S3
# Copy this file to .env and update with your actual values

# =============================================================================
# DATABASE CONFIGURATION (PostgreSQL)
# =============================================================================
# Format: postgresql://username:password@host:port/database
DATABASE_URL=sqlite:///./fashionfusion.db

# =============================================================================
# S3 STORAGE CONFIGURATION
# =============================================================================
# AWS S3 or S3-compatible storage (DigitalOcean Spaces, MinIO, etc.)
S3_BUCKET=your_bucket_name
S3_ACCESS_KEY=your_s3_access_key
S3_SECRET_KEY=your_s3_secret_key
S3_REGION=your_s3_region
# For non-AWS S3 (optional):
# S3_ENDPOINT=https://nyc3.digitaloceanspaces.com

# =============================================================================
# SECURITY
# =============================================================================
SECRET_KEY=your_secret_key_change_in_production
JWT_SECRET=your_jwt_secret_key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# =============================================================================
# AI SERVICES
# =============================================================================
# Google AI Studio (500 free images/day)
GOOGLE_API_KEY=your_google_api_key
# Virtual Try-On API (optional)
TRYON_API_KEY=your_tryon_api_key



# =============================================================================
# APPLICATION URLS
# =============================================================================
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# =============================================================================
# DATABASE POOL SETTINGS (PostgreSQL)
# =============================================================================
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# =============================================================================
# AI MODEL CONFIGURATION
# =============================================================================
STABLE_DIFFUSION_MODEL=black-forest-labs/flux-dev
IMG2IMG_MODEL=black-forest-labs/flux-dev
CONTROLNET_MODEL=black-forest-labs/flux-dev
