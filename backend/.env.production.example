# Production Environment Variables
# Copy this to .env.production and update with your actual values

# Database
DATABASE_URL=postgresql://username:password@your-db-host:5432/fashionfusion_prod

# API URLs (Production)
BACKEND_URL=https://api.yourdomain.com
FRONTEND_URL=https://yourdomain.com

# Security
JWT_SECRET=your-super-secure-jwt-secret-for-production

# Replicate API (FLUX Model)
REPLICATE_API_TOKEN=r8_your-replicate-api-token

# TryOn API (Paid plan for production)
TRYON_API_KEY=your-tryon-api-key

# AWS S3 Storage (Production)
S3_BUCKET=fashionfusion-prod-storage
S3_ACCESS_KEY=your-aws-access-key
S3_SECRET_KEY=your-aws-secret-key
S3_REGION=us-east-1
